{
  "buildCommand": "npm run build && npm run build:inngest",
  "installCommand": "npm install",
  "outputDirectory": "dist/client",
  "rewrites": [
    { "source": "/api/inngest/:path*", "destination": "/api/inngest" },
    { "source": "/((?!assets/).*)", "destination": "/api/server" }
  ],
  "functions": {
    "api/server.js": {
      "includeFiles": "dist/server/**"
    },
    "api/inngest.js": {
      "includeFiles": [
        "dist/server/inngest-handler.js",
        "dist/server/agent-executor.js"
      ],
      "maxDuration": 300
    }
  }
}
