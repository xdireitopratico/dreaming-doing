{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sync:agent-contract": "node scripts/sync-agent-contract.mjs",
    "check:agent-contract": "node scripts/sync-agent-contract.mjs --check",
    "dev": "vite dev",
    "build": "cross-env VERCEL=1 vite build",
    "build:cloudflare": "vite build",
    "build:vercel": "cross-env VERCEL=1 vite build",
    "build:inngest": "node scripts/build-agent-executor.mjs && node scripts/build-inngest.mjs",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "test:agent-journey": "vitest run src/lib/chat/agent-turn-flow.test.ts src/lib/lovable-acceptance.test.ts src/lib/chat-reliability.test.ts src/lib/inspector-live-stream.test.ts",
    "check:lovable-visual": "node scripts/lovable-visual-check.mjs",
    "check:dashboard-journey": "node scripts/dashboard-editor-journey.mjs",
    "check:plan-dock-journey": "E2E_PHASES=dashboard,plan-dock E2E_PLAN_DOCK_REQUIRED=1 node scripts/dashboard-editor-journey.mjs",
    "check:agent-browser": "node scripts/lovable-visual-check.mjs && node scripts/dashboard-editor-journey.mjs",
    "setup:e2e-auth": "node scripts/setup-e2e-auth.mjs",
    "check:agent-gates": "npm run test:agent-journey && npm run smoke:agent && node scripts/check-stale-runs.mjs --cleanup",
    "check:deploy-gates": "npm run check:agent-contract && npm run test:agent-journey && npm run check:agent-gates && npm run check:agent-metrics && npm run check:shadow-parity",
    "smoke:agent": "node scripts/smoke-agent-e2e.mjs",
    "smoke:aetherforge": "node scripts/smoke-aetherforge-e2e.mjs",
    "smoke:prometheus": "node scripts/smoke-prometheus-e2e.mjs --with-gateway",
    "smoke:gateway-tools": "node scripts/smoke-gateway-tenant-secrets-e2e.mjs",
    "smoke:gateway-matrix": "node scripts/smoke-gateway-tenant-secrets-e2e.mjs --tool=all",
    "smoke:gateway-inngest": "node scripts/smoke-gateway-inngest-e2e.mjs",
    "smoke:queue": "node scripts/smoke-queue-e2e.mjs",
    "smoke:stability": "npm run test -- --run src/lib/assistant-materialized.test.ts src/lib/chat/thread.test.ts src/lib/forge-run.test.ts",
    "check:stale-runs": "node scripts/check-stale-runs.mjs",
    "check:agent-metrics": "node scripts/check-agent-run-metrics.mjs",
    "check:shadow-parity": "node scripts/check-shadow-parity.mjs",
    "check:inngest": "node scripts/check-inngest-health.mjs",
    "bundle:skills": "node scripts/bundle-forge-skills.mjs",
    "bundle:forge-ui": "node scripts/bundle-forge-ui-seed.mjs"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.25.5",
    "@forge/agent-contract": "workspace:*",
    "@forge/ui": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@lovable.dev/cloud-auth-js": "^1.1.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
