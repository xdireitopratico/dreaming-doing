# ═══════════════════════════════════════════════════════════════════════
# Config para debug-log.sh
# Copie para .env.debug e preencha:
#   cp .env.debug.example .env.debug
# ═══════════════════════════════════════════════════════════════════════

# ─── Supabase ───
SUPABASE_PROJECT_REF=xxxxxx
SUPABASE_PAT=  # Personal Access Token (Dashboard → Settings → API → Personal Access Token)

# Telemetria (agent_streaming_telemetry) — opcional se .env.local já tiver:
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=  # service_role (Settings → API)

# ─── Vercel ───
VERCEL_TOKEN=      # Vercel Access Token (Dashboard → Settings → Tokens)
VERCEL_PROJECT=    # Nome do projeto (ex: dreaming-doing)

# ─── Inngest ───
INNGEST_SIGNING_KEY=  # Signing Key (Inngest Cloud → Environment → Signing Keys)
INNGEST_ENV_ID=       # Environment ID (Inngest Cloud → Environment → Settings)
