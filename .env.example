# Supabase exclusivo — Dreaming and Doing (dpduljngdurfpmaclffa)
# Copie para .env e preencha a service_role no dashboard se necessário (servidor/CI apenas).

VITE_SUPABASE_URL=https://dpduljngdurfpmaclffa.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
VITE_SUPABASE_PROJECT_ID=dpduljngdurfpmaclffa

SUPABASE_URL=https://dpduljngdurfpmaclffa.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key

# Opcional: Secrets em Supabase Dashboard → Edge Functions → Secrets
# (alternativa à página /connectors). Ex.: ANTHROPIC_API_KEY, GROQ_API_KEY

# Agent runtime v2 (Edge + Inngest + Vercel): off | shadow | worker
# shadow = grava agent_jobs + executor v1 com fallback
# worker = 1 job/chunk, lease obrigatório (Fase 1.5)
# AGENT_RUNTIME_V2=shadow

# E2E browser (scripts/dashboard-editor-journey.mjs) — opcional
# OPENROUTER_API_KEY=sk-or-...  # recomendado; modelo free nex-agi/nex-n2-pro:free
# E2E_MODEL=nex-agi/nex-n2-pro:free
# E2E_E2B_KEY=...                # fallback: copia sandbox do admin
# INNGEST_EVENT_KEY=...          # bootstrap Inngest nos gates browser
# INNGEST_SIGNING_KEY=...        # worker connect na VM (sync: npm run sync:inngest-signing-key)

# Hostinger VM (workers + Redis) — token em ~/.env.local como HOSTINGER_KEY
# HOSTINGER_VM_HOST=187.77.239.8
# HOSTINGER_VM_ID=1484367
# VM deploy: npm run deploy:vm-workers
# Executor Inngest: só VM — Vercel /api/inngest retorna 410